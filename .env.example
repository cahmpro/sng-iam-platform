# ============================================================================
# Configuration Sign&go IAM Platform
# Copier ce fichier en .env et remplir toutes les valeurs
# Générer les secrets avec : ./scripts/gen-secrets.sh
# ============================================================================

# --- Domaine ---
# Remplacer par votre domaine. Tous les sous-domaines suivants doivent exister :
# - admin.<DOMAIN>     → Sign&go admin
# - user.<DOMAIN>      → Sign&go portail user
# - traefik.<DOMAIN>   → Dashboard Traefik
# - grafana.<DOMAIN>   → Grafana (étape 1.2)
# - ids.<DOMAIN>       → IDSphere (étape 1.3)
DOMAIN=example.com

# --- Let's Encrypt ---
LETSENCRYPT_EMAIL=admin@example.com

# --- Cloudflare API (DNS-01 challenge) ---
# Token avec permissions Zone:DNS:Edit + Zone:Zone:Read sur votre zone
# Créer sur : https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=cf_token_here

# --- PostgreSQL (3 bases Sign&go) ---
DB_PASSWORD=changeme

# --- Sign&go ---
ADMIN_PASSWORD=changeme
AGENT_LOCAL_PWD=changeme
SIGNANDGO_LICENSE=signandgo_license_string_here

# --- Traefik dashboard (basic auth) ---
# Générer avec : htpasswd -nbB admin <password> | sed 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replace_with_real_hash

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=changeme

# --- IDSphere ---
IDS_DB_PASSWORD=changeme
IDS_ADMIN=changeme
IDS_WORKFLOW_JWT_PASSPHRASE=changeme_32_chars_minimum
IDS_LICENSE=idsphere_license_string_here
IDS_CONTEXT_PATH=/
