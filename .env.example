# === Domaine ===
DOMAIN=cah.formindemo.fr

# === Mots de passe applicatifs Sign&go ===
# Générer avec : openssl rand -base64 24
DB_PASSWORD=
ADMIN_PASSWORD=

# === Let's Encrypt ===
LETSENCRYPT_EMAIL=

# === Cloudflare DNS-01 ===
# Token API Cloudflare avec permissions Zone:Read + DNS:Edit sur formindemo.fr
CF_DNS_API_TOKEN=

# === Traefik dashboard (basic auth) ===
# Générer avec : docker run --rm httpd:2.4-alpine htpasswd -nB admin
# Doubler les $ dans la valeur ($ -> $$) pour échapper
TRAEFIK_DASHBOARD_AUTH=

# === Grafana ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# IDSphere
IDS_LICENSE=<licence IDSphere fournie par Ilex>
IDS_ADMIN=<mot de passe admin IDSphere>
IDS_WORKFLOW_JWT_PASSPHRASE=<secret JWT 32+ chars>
IDS_DB_PASSWORD=<mot de passe Postgres IDSphere>
IDS_CONTEXT_PATH=/
